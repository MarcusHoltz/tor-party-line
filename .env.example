# Tor Party Line — environment overrides
# Copy this to .env and uncomment the lines you need.
# docker compose run --rm partyline reads this automatically.

# ─── Audio ───────────────────────────────────────────────────────────────────
#
# Native runs prefer the system sound server (parecord/paplay → PulseAudio or
# PipeWire) and follow your desktop's default mic/speakers — usually no settings
# needed here. Pick a specific device in-app via Settings → 7 → Audio devices.
#
# Setting ALSA_DEVICE or ALSA_PLAY_DEVICE below FORCES the ALSA-direct backend
# (bypassing the sound server). Use this for Docker, headless/daemon setups, or
# bare-ALSA systems. Docker always uses ALSA direct via /dev/snd.
#
# To find your device numbers, run on the HOST (not inside Docker):
#   arecord -l    — lists capture devices (microphones)
#   aplay -l      — lists playback devices (speakers)
#
# Use plughw (recommended) to allow automatic format conversion, or hw for
# exact hardware access (may require matching sample rate/format).

# Capture device (microphone) — blank = sound-server default; set = force ALSA
#ALSA_DEVICE=plughw:2,0

# Playback device (speakers) — blank = sound-server default / same card as capture
#ALSA_PLAY_DEVICE=plughw:0,0

# PipeWire/PulseAudio capture device name — blank = system default sound server; set to
# override (e.g. alsa_input.pci-0000_00_1f.3.analog-stereo). Use in-app picker to find names.
#PULSE_SOURCE=

# PipeWire/PulseAudio playback device name — blank = system default; set to override.
#PULSE_SINK=

# ─── Docker audio: PulseAudio/PipeWire socket ────────────────────────────────
#
# In Docker mode, audio routes through the host user's PipeWire session via the
# PulseAudio-compatible socket at /run/user/<UID>/pulse/native.  This is mounted
# into the container automatically from the host shell's $XDG_RUNTIME_DIR.
#
# If your user ID is not 1000, set this before running docker compose:
#   export XDG_RUNTIME_DIR=/run/user/$(id -u)
# Or uncomment and set it here:
#XDG_RUNTIME_DIR=/run/user/1000

# ─── Call settings (Docker `.env` ↔ CLI flag parity) ─────────────────────────
#
# Each variable below is the `.env` equivalent of a command-line flag, so Docker
# users get the same control as `./partyline.sh --flag` users. A CLI flag passed
# to `docker compose run` still overrides the matching .env value. See the README
# "CLI flags ↔ .env" table for the full mapping.
#
# NOTE: the SHARED SECRET is deliberately NOT set here. Environment variables can
# leak (via `docker inspect`, `/proc/<pid>/environ`, container logs), so the
# secret is a bind-mounted file instead — put it in secrets/shared_secret.txt
# (the secrets/ dir is bind-mounted read-only into the container; see
# docker-compose.yml and the README).

# Tor hidden service listen port — flag: -p/--port (default: 7777)
#LISTEN_PORT=7777

# Tor SOCKS port the app dials out through — flag: --socks-port.
# In Docker this is fixed at 9050: the entrypoint's generated torrc always binds
# SocksPort 9050 (entrypoint.sh) and ignores this var for the torrc, so changing it
# here would point the app at a port Tor isn't listening on. Leave it unless you
# also change the torrc. (9052 is the native-script default.)
#TOR_SOCKS_PORT=9050

# Opus bitrate in kbps — flag: -b/--bitrate (default: 16; raise to 24-32 for better quality)
#OPUS_BITRATE=16

# OpenSSL cipher — flag: -c/--cipher (default: aes-256-cbc; e.g. aes-256-gcm)
#CIPHER=aes-256-cbc

# HMAC-sign all protocol messages — flag: --hmac/--no-hmac (0 = off, 1 = on; default: 1)
#HMAC_AUTH=1

# Use the Snowflake bridge — flag: --snowflake/--no-snowflake (0/1; default: 0)
#SNOWFLAKE_ENABLED=0

# Single-hop hidden service (faster, less anonymous) — flag: --single-hop/--no-single-hop (0/1; default: 0)
#SINGLE_HOP=0

# Auto-listen after Tor starts — flag: --auto-listen/--no-auto-listen (0/1; default: 0)
#AUTO_LISTEN=0

# Show Tor circuit hops in the call header — flag: --show-circuit/--no-show-circuit (0/1; default: 0)
#SHOW_CIRCUIT=0

# Tor ExcludeNodes — flag: --exclude-nodes (e.g. '{US},{GB}'; default: none)
#EXCLUDE_NODES={US},{GB}

# Liveness / keep-alive tuning.
#
# RELAY_IDLE_TIMEOUT: relay drops a caller after this many seconds of total silence
#   (no audio/chat/PING). During PTT recording, the heartbeat PING is suppressed —
#   the relay sees silence for the full recording duration (up to MAX_PTT_SECONDS=120 s)
#   plus encode+Tor delivery time for the first AUDIO chunk (~23 s worst case). So:
#     RELAY_IDLE_TIMEOUT must be > MAX_PTT_SECONDS + HEARTBEAT_INTERVAL + ~20 s Tor
#     240 > 120 + 20 + 20 = 160  (80 s headroom — do not lower below ~160 s)
#   Also controls zombie-caller duration: a dropped caller is not reaped for this long.
#   Default: 240.
# HEARTBEAT_INTERVAL: each caller sends a PING every this many seconds so a quiet
#   connection is not mistaken for a dropout. Keep it well below RELAY_IDLE_TIMEOUT.
#   See RELAY_IDLE_TIMEOUT constraint above — changing this affects the minimum safe
#   RELAY_IDLE_TIMEOUT. Default: 20.
# CLIENT_TIMEOUT: the client treats no INBOUND traffic for this many seconds as a
#   dropped connection and tears the call down (then auto-reconnects — see below).
#   A live link always feeds the client something well within this window (the relay
#   beacons a GROUP count every ~10s and forwards peer PINGs; a direct peer PINGs every
#   HEARTBEAT_INTERVAL), so set it comfortably above those. Default: 180.
# RECONNECT_ATTEMPTS: after a detected drop, the dialing side silently re-dials this
#   many times to ride out Tor circuit hiccups before giving up to the menu. Set 0 to
#   disable auto-reconnect. Default: 3.
#
# Android note: on Termux the script now holds a partial wakelock for the duration of
# a call so a locked screen can't deep-sleep the CPU and freeze the heartbeat. Install
# the termux-api package (and the Termux:API app) for wakelock support.
#RELAY_IDLE_TIMEOUT=240
#HEARTBEAT_INTERVAL=20
#CLIENT_TIMEOUT=180
#RECONNECT_ATTEMPTS=3

# Anti-flood / DoS limits. The relay has no shared secret and cannot verify traffic,
# so flood defense lives at the relay itself. Sensible defaults; raise only if you
# understand the trade-off.
#
# MAX_PTT_SECONDS: hard cap on a single push-to-talk transmission. The recorder
#   self-terminates after this long even if the key is held, so a stuck/held PTT
#   can't produce an unbounded blob. At the default 16 kbps Opus, 120 s ~= 320 KB
#   base64, comfortably under MAX_LINE_BYTES. Default: 120.
# MAX_AUDIO_B64: the sender skips an AUDIO blob whose base64 exceeds this — it would
#   be dropped at the relay anyway, so this avoids wasting Tor upload bandwidth. It is
#   the bitrate-robust backstop to MAX_PTT_SECONDS. Defaults to MAX_LINE_BYTES (512 KB).
# MAX_LINE_BYTES: the relay drops any inbound line larger than this before forwarding,
#   preventing memory exhaustion from an oversized paste/blob. Default: 524288 (512 KB).
# MAX_MSG_B64: a receiving client drops a MSG whose base64 exceeds this. Default: 65536.
# RELAY_MAX_MSG_PER_SEC: the relay drops a single caller's messages beyond this many
#   per second, so one caller can't flood/mute the others. Audio is ~1 msg/s during
#   active talk, so the default leaves wide headroom. Default: 15.
# RELAY_MAX_INFLIGHT: caps how many background FIFO-forward writes run at once per
#   caller (the fork-bomb guard against a flood or a stalled reader). Default: 64.
# RELAY_WRITE_TIMEOUT: seconds before the relay abandons a write to a slow/stalled
#   client, so one wedged caller can't block forwarding to everyone. Sized to handle a
#   28 KB AUDIO: chunk (~10 s at 16 kbps) draining at 5 KB/s worst-case Tor (~6 s) with
#   headroom; dead clients are abandoned within this window. Default: 30.
# DECRYPT_TIMEOUT: seconds before killing a stalled openssl decrypt process (anti-hang
#   guard for a wedged cipher operation). Default: 10.
# PTT_CHUNK_SECONDS: split a PTT recording into chunks of this many seconds before
#   encoding and sending each piece. Smaller = lower perceived latency at the receiver;
#   larger = fewer socat round-trips. Default: 10.
#MAX_PTT_SECONDS=120
#MAX_AUDIO_B64=524288
#MAX_LINE_BYTES=524288
#MAX_MSG_B64=65536
#RELAY_MAX_MSG_PER_SEC=15
#RELAY_MAX_INFLIGHT=64
#RELAY_WRITE_TIMEOUT=30
#DECRYPT_TIMEOUT=10
#PTT_CHUNK_SECONDS=10
