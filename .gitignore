# ─── Project runtime data ─────────────────────────────────────────────────────
# All persistent data lives here. data/script/ = Host OS, data/docker/ = Docker.
data/
# Script-mode runtime dir: Tor hidden-service keys, shared_secret, torrc, pids.
.torpartyline/

# ─── Secrets & environment ────────────────────────────────────────────────────
secrets/*
# keep the dir on clone so Docker's bind mount has a host path; ignore everything inside (incl. the real secret)
!secrets/.gitkeep
.env
.env.*
# keep the committed template; .env.* above would swallow it without this exception
!.env.example
*.env
.env.local
.env.production

# ─── Version control ──────────────────────────────────────────────────────────
.git/
.gitattributes

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

